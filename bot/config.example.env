# Copy this file to  bot/.env  and fill in your values.
# .env is git-ignored so your keys never get committed.
#
# This is a SHORT-TERM INVESTING bot (~3-month horizon), not a scalper. It ranks
# the underlying US stocks by momentum + trend + quality (+dividends) and HOLDS
# the best ones for weeks/months, rotating only when something better appears or
# a holding breaks down.

# Manual-sell button on the web monitor — protect it with a token (recommended,
# the URL is public). Empty = no token.
# MONITOR_TOKEN=choose-a-secret

# ---- cloud hosting (Railway/Render/VPS) ----
# PORT is set by the host; the bot then serves its web monitor there.
# PORT=8000
# DATA_DIR keeps state/trades on a persistent volume across redeploys.
# DATA_DIR=/data

# ---- mode ----
# dryrun = no real orders (safe) | testnet = fake money | live = REAL money
BOT_MODE=dryrun
# LIVE safety latch — live mode refuses to start unless this is set exactly:
# CONFIRM_LIVE=I_UNDERSTAND_THE_RISK

# ---- API keys (only for testnet/live) ----
# TRADE-ONLY key, WITHDRAWALS DISABLED, IP restriction ON.
# NOTE: bStocks are NOT available to US persons / some regions — be eligible,
# and deploy from a non-US region (Binance.com geo-blocks US servers).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- Finnhub (FREE, strongly recommended for this strategy) ----
# Free key at https://finnhub.io (60 calls/min). Feeds analyst conviction,
# earnings growth and dividend yield of the UNDERLYING stock into the score.
# Without it the bot still ranks on momentum/trend, just with less quality info.
FINNHUB_API_KEY=

# ---- what to invest in ----
# Curated Binance bStocks (tokenized US equities). Symbol = ticker + "B" + USDT.
SYMBOLS=NVDABUSDT,TSLABUSDT,CRCLBUSDT,SNDKBUSDT,MUBUSDT,AMDBUSDT,INTCBUSDT,MSTRBUSDT,EWYBUSDT
# Auto-detect newly listed bStocks instead of the fixed basket.
AUTO_UNIVERSE=false
MIN_QUOTE_VOLUME=0
MAX_UNIVERSE=60

# ---- portfolio / sizing (tuned for a small account) ----
TOP_N=3                  # hold the best N names
MAX_OPEN_POSITIONS=3
QUOTE_PER_TRADE=50       # USDT per position (keep >= ~11 to clear Binance minimum)
MIN_SCORE=0              # a stock must score above this (and be in an uptrend) to be held

# ---- exits (wide — this is investing, let winners run) ----
STOP_LOSS_PCT=18         # hard protective stop
TRAILING_STOP_PCT=15     # lock gains: sell on a 15% pullback from the peak
TAKE_PROFIT_PCT=0        # 0 = no fixed target (ride momentum); e.g. 35 to bank +35%
TREND_EXIT=true          # exit a holding when the underlying breaks its 200-day line
MAX_SPREAD_PCT=0.8       # skip entry if the bStock spread is wider than this %

# ---- entry gates ----
# Don't buy while the broad market (S&P 500) is below its 200-day average.
MARKET_TREND_FILTER=true
MARKET_TREND_MA=200
# Don't buy into a VIX panic / (optionally) outside US market hours.
DERIVATIVES_GATE=true
PANIC_VIX=40
TRADE_RTH_ONLY=false
# Don't buy on strong negative news (reads docs/stocks/data/news.json).
NEWS_GATE=true
# Pause: open NO new positions, but keep managing/exiting open ones.
PAUSE_TRADING=false

# ---- risk ----
DAILY_LOSS_LIMIT=0       # 0 = off; e.g. 30 = stop new buys after losing 30 USDT/day
PAPER_EQUITY=500         # starting equity for dryrun accounting only

# ---- cadence (slow — investing, not scalping) ----
POLL_SECONDS=300         # how often to check exits / prices
REALTIME_LEARNING=false  # false = rebalance on the OPTIMIZE_HOURS schedule
OPTIMIZE_HOURS=12        # how often to re-rank & rotate holdings
LEARN_SECONDS=3600       # only used if REALTIME_LEARNING=true

# ---- publish dashboard + durable state backup (optional) ----
PUBLISH_DASHBOARD=false
GITHUB_TOKEN=
GH_REPO=salem0557/binance-stock-bot
PUBLISH_BRANCH=bot-live
PUBLISH_SECONDS=60
