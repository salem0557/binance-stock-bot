# Copy this file to  bot/.env  and fill in your values.
# .env is git-ignored so your keys never get committed.

# Manual-sell button: the live monitor (your hosting URL) shows a "بيع" button
# next to each open position so you can market-sell by hand if needed. Set a
# token to require it before a sell is accepted (recommended since the URL is
# public). Enter the same token once in the dashboard field. Empty = no token.
# MONITOR_TOKEN=choose-a-secret

# ---- cloud hosting (Railway/Render/VPS) ----
# PORT is set automatically by the host; the bot then serves a web monitor
# (dashboard + live logs) at that URL. Locally you can set it to e.g. 8000.
# PORT=8000
# DATA_DIR keeps state/models/trades on a persistent volume across redeploys.
# DATA_DIR=/data

# ---- mode ----
# dryrun = no real orders (safe) | testnet = fake money | live = REAL money
BOT_MODE=dryrun

# LIVE safety latch — live mode refuses to start unless this is set exactly:
# CONFIRM_LIVE=I_UNDERSTAND_THE_RISK

# ---- API keys (only for testnet/live) ----
# Create a TRADE-ONLY key with WITHDRAWALS DISABLED and IP restriction ON.
# Testnet keys come from https://testnet.binance.vision (not your real account).
# NOTE: bStocks (tokenized US stocks) are NOT available to US persons and some
# regions. Make sure your account is eligible before going to testnet/live.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- what to trade ----
# Fixed basket of Binance bStocks (tokenized US equities). Used when
# AUTO_UNIVERSE=false (the default — the list of bStocks is small and curated).
# Symbol = stock ticker + "B" + "USDT" (e.g. NVIDIA = NVDABUSDT, Tesla = TSLABUSDT).
SYMBOLS=NVDABUSDT,TSLABUSDT,CRCLBUSDT,SNDKBUSDT,MUBUSDT,AMDBUSDT,INTCBUSDT,MSTRBUSDT,EWYBUSDT
TOP_N=4

# AUTO_UNIVERSE: auto-detect newly listed bStocks instead of the fixed basket.
# It scans Binance for USDT pairs whose base asset looks like a tokenized stock
# (ends in "B"), ranks them by 24h volume, deep-optimizes a rolling SHORTLIST,
# and trades the best TOP_N. Off by default — the curated SYMBOLS basket above
# is the reliable choice; turn this on to pick up new listings automatically.
AUTO_UNIVERSE=false
MIN_QUOTE_VOLUME=0         # ignore illiquid names (24h volume below this). 0 = all
MAX_UNIVERSE=60            # cap the auto universe size
SCAN_BATCH=20             # pairs quick-scanned per cycle (rotates through all)
SHORTLIST=12              # best scanned pairs to deep-optimize & pick TOP_N from

# ---- strategy / speed ----
# crossover = slow trend trades (few signals) | scalp = active short-term trader
# (many quick entries, tight stop-loss/take-profit).
STRATEGY=crossover
INTERVAL=1h              # for active intraday trading try 15m or 5m
HISTORY=1000            # candles fetched per symbol for backtest/ML. More history
                        # = a bigger held-out set = a more trustworthy ML accuracy.

# ---- sizing & risk (tuned for a ~500 USDT account) ----
QUOTE_PER_TRADE=50       # USDT spent per buy
MAX_OPEN_POSITIONS=4     # 4 × 50 = up to 200 USDT deployed, rest is buffer
DAILY_LOSS_LIMIT=30      # 0 = off; e.g. 30 = halt new buys after losing 30 USDT/day
# Trailing stop: ride the rise, sell when price pulls back this % from its peak.
# 0 = off (use the optimizer's fixed take-profit). e.g. 2 = sell on a 2% pullback.
TRAILING_STOP_PCT=0

# ---- fixed exit rules (override the optimizer's auto-tuned values) ----
# 0 = let the optimizer choose. Set both to force e.g. "sell at +4% or -1%".
TAKE_PROFIT_PCT=0        # sell when a position is up this %  (ignored if trailing on)
STOP_LOSS_PCT=0          # sell when a position is down this %

# Min ML "up" probability to allow a buy. Lower = more (riskier) trades.
# The ML model reports HONEST out-of-sample accuracy; a name whose model has no
# real edge is ignored, so the bot falls back to the technical signal.
ML_BUY_THRESHOLD=0.55

# Escape filter: skip entry if the bid/ask spread is wider than this % (a wide
# spread = thin name you can't exit cleanly). 0 = off. 0.5 = sensible.
MAX_SPREAD_PCT=0.5

# News gate: block buys on strong negative stock news (earnings misses,
# downgrades, probes...). Reads docs/stocks/data/news.json. Set false to trade
# through it (a deployed news.json can be stale and would otherwise block buys).
NEWS_GATE=true

# Relative-strength gate (the stock equivalent of the crypto "smart money"
# long/short ratio): only confirm a buy when the stock isn't badly lagging the
# S&P 500 over the last ~10 sessions. RS >= SMART_MONEY_MIN required.
# 1.0 = matching the market; <1 = lagging; >1 = outperforming. 0.97 allows a
# little underperformance. Names without enough data are treated as neutral.
SMART_MONEY_GATE=true
SMART_MONEY_MIN=0.97

# Pause switch: true = open NO new positions, but keep managing and exiting
# the ones already open (stop-loss / trailing / take-profit all still run).
PAUSE_TRADING=false

# ---- market-trend filter (anti-bear) ----
# A long-only bot bleeds when it keeps buying dips in a falling market. When ON,
# the bot opens NO new longs while the S&P 500 is below its long moving average
# (bear), and resumes automatically when it reclaims it (bull). Exits always run.
# The S&P 500 (SPY) daily series is fetched free from Stooq — no API key.
MARKET_TREND_FILTER=true
MARKET_TREND_MA=200        # MA length on the S&P 500 DAILY closes (200 = classic)

# Name-quality filter: skip auto-discovered names whose recent per-bar
# volatility (std-dev of returns) exceeds this %. 0 = off. Only affects
# AUTO_UNIVERSE scanning (your fixed SYMBOLS basket is never filtered out).
MAX_VOLATILITY_PCT=0

# ---- market-session / VIX risk gate (the funding-froth equivalent) ----
# bStocks trade 24/7, but the underlying shares only price during US market
# hours, and a long-only dip-buyer shouldn't buy into a market in free-fall.
# This gate vetoes a buy when the VIX is in panic (>= PANIC_VIX) and, if you
# turn it on, when outside US regular trading hours. Off = DERIVATIVES_GATE=false.
DERIVATIVES_GATE=true
PANIC_VIX=40               # VIX at/above this = panic; stand aside
TRADE_RTH_ONLY=false       # true = only enter during 09:30-16:00 ET (Mon-Fri)

# ATR volatility stop: stop distance = max(tuned %, ATR×mult). 0 = off (fixed %
# only). ~1.5-2.5 adapts the stop to each name's real volatility so normal
# noise doesn't whipsaw you out. Needs high/low candles (fetched automatically).
ATR_STOP_MULT=0
ATR_PERIOD=14

PAPER_EQUITY=500         # starting equity for dryrun accounting only

# ---- publish dashboard + durable state backup (optional) ----
# Backs up state.json to GitHub (restored on boot) so the bot keeps open
# positions on a stateless cloud host. Pushed to a SEPARATE branch.
PUBLISH_DASHBOARD=false
GITHUB_TOKEN=             # fine-grained PAT with Contents: Read & Write on the repo
GH_REPO=salem0557/binance-stock-bot
PUBLISH_BRANCH=bot-live
PUBLISH_SECONDS=60       # how often to push the snapshot

# ---- timing / self-learning ----
POLL_SECONDS=30           # how often to manage positions / react to price
LEARN_SECONDS=60          # how often to run the heavy scan+optimize (decoupled
                          # from POLL_SECONDS so exits stay fast).
REALTIME_LEARNING=true    # true = re-tune on the LEARN_SECONDS cadence.
                          # false = use the slower OPTIMIZE_HOURS schedule.
OPTIMIZE_HOURS=2          # only used when REALTIME_LEARNING=false
ML_RETRAIN_MINUTES=10     # how often to retrain the ML model (0 = every cycle).
